rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Role & identity helpers ─────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function incomingData() {
      return request.resource.data;
    }

    function existingData() {
      return resource.data;
    }

    function isValidString(field) {
      return field is string && field.size() > 0 && field.size() <= 5000;
    }

    function userDoc(uid) {
      let docSnap = get(/databases/$(database)/documents/users/$(uid));
      return docSnap == null ? null : docSnap.data;
    }

    function callerRole() {
      let d = userDoc(request.auth.uid);
      return d == null ? 'user' : d.get('role', 'user');
    }

    // Hardcoded permanent admin — zero-cost bypass, no get() needed
    function isHardcodedAdmin() {
      return isAuthenticated() && request.auth.uid == '3lTGqbbqMEdJjrZ0UUNEmwWTJN22';
    }

    function isAdmin() {
      return isHardcodedAdmin() || (isAuthenticated() && callerRole() == 'admin');
    }

    function isSuperAdmin() {
      return isHardcodedAdmin() || (isAuthenticated() && callerRole() == 'superadmin');
    }

    function isModerator() {
      // Check hardcoded admin first (no get() cost), then fall back to role lookup
      return isHardcodedAdmin() || (isAuthenticated() && callerRole() in ['moderator', 'admin', 'superadmin']);
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function protectedUserFields() {
      return [
        'role', 'karma', 'level', 'isPremium', 'isVerified',
        'emailVerified', 'createdAt'
      ];
    }

    function ownerCannotEscalate() {
      return !incomingData().diff(existingData()).affectedKeys()
        .hasAny(protectedUserFields());
    }

    function ownerFcmOnly() {
      let diff = incomingData().diff(existingData()).affectedKeys();
      let fcmTouched = diff.hasAny(['fcmToken', 'fcmTokens']);
      return !fcmTouched || diff.hasOnly(['fcmToken', 'fcmTokens', 'lastActive', 'isOnline', 'lastSeen']);
    }

    function businessOwnerOnlyFields() {
      return ['rating', 'reviewCount', 'views', 'contactClicks', 'updatedAt'];
    }

    function businessPrivilegedFields() {
      return ['isVerified', 'isPremium', 'verificationStatus', 'subscriptionPlan', 'featuredUntil', 'promotionLevel', 'verified', 'featured'];
    }

    // ─── Users ───────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated();

      allow create: if isOwner(userId)
        && incomingData().uid == userId
        && incomingData().get('role', 'user') == 'user'
        && incomingData().get('isPremium', false) == false;

      allow update: if (
        isOwner(userId)
        && incomingData().uid == userId
        && ownerCannotEscalate()
        && ownerFcmOnly()
        && incomingData().email == existingData().email
      ) || (
        isAuthenticated()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers', 'following'])
      ) || (
        isAdmin() || isSuperAdmin()
      );

      allow delete: if isOwner(userId) || isAdmin() || isSuperAdmin();

      match /karma_history/{historyId} {
        allow read: if isOwner(userId);
        allow create: if isAuthenticated();
        allow delete: if isOwner(userId);
      }
    }

    // ─── Posts ───────────────────────────────────────────────────────────
    match /posts/{postId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated()
        && isEmailVerified()
        && incomingData().userId == request.auth.uid
        && isValidString(incomingData().title)
        && isValidString(incomingData().communityId)
        && incomingData().title.size() <= 200
        && incomingData().get('description', '').size() <= 5000;

      allow update: if isAuthenticated() && (
        (existingData().userId == request.auth.uid
          && incomingData().userId == existingData().userId)
        || request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['likedBy', 'likes', 'likesCount', 'responderIds', 'responderDetails', 'respondersCount', 'commentsCount', 'status', 'cancelledAt'])
        || isModerator()
      );

      allow delete: if (isAuthenticated()
        && existingData().userId == request.auth.uid) || isModerator();

      match /comments/{commentId} {
        allow read: if isAuthenticated();

        allow create: if isAuthenticated()
          && isEmailVerified()
          && incomingData().userId == request.auth.uid
          && isValidString(incomingData().content)
          && incomingData().content.size() <= 2000;

        allow update: if isAuthenticated()
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['likedBy', 'likesCount']);

        allow delete: if (isAuthenticated()
          && existingData().userId == request.auth.uid) || isModerator();
      }
    }

    // ─── Conversations & messages ─────────────────────────────────────────
    // NOTE: We avoid calling userDoc() in read rules to prevent permission
    // errors when the user document is not yet fully initialized.
    match /conversations/{conversationId} {
      // Participants can always read their own conversations.
      // Community conversations: any authenticated user can read
      // (client filters by communityId). This avoids expensive cross-doc gets.
      allow get: if isAuthenticated() && (
        resource == null
        || request.auth.uid in resource.data.participants
        || resource.data.type == 'community'
      );

      allow list: if isAuthenticated() && (
        request.auth.uid in resource.data.participants
        || resource.data.type == 'community'
      );

      allow create: if isAuthenticated()
        && isEmailVerified()
        && (
          (incomingData().type == 'dm'
            && request.auth.uid in incomingData().participants
            && incomingData().participants.size() == 2)
          || incomingData().type == 'community'
        );

      allow update: if isAuthenticated() && (
        // Participants updating DM metadata
        (request.auth.uid in existingData().participants
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['lastMessage', 'lastMessageAt', 'lastSenderId', 'readBy', 'typing', 'unreadCounts', 'participantNames', 'participants']))
        // Community conversations: any authenticated user can update metadata
        || (existingData().type == 'community'
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['lastMessage', 'lastMessageAt', 'lastSenderId', 'readBy', 'typing', 'unreadCounts', 'participants', 'participantNames']))
      );

      allow delete: if isAuthenticated()
        && request.auth.uid in existingData().participants
        && existingData().type == 'dm';

      match /messages/{messageId} {
        // Messages: any authenticated user can read.
        // Conversation-level access is already gated by the parent rules.
        allow read: if isAuthenticated();

        allow create: if isAuthenticated()
          && isEmailVerified()
          && (
            (incomingData().senderId == request.auth.uid
              && (request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants
                  || get(/databases/$(database)/documents/conversations/$(conversationId)).data.type == 'community')
              && incomingData().get('text', '').size() <= 5000)
            || (incomingData().senderId == 'system_sos'
              && incomingData().type == 'sos_alert')
          );

        allow update: if isAuthenticated()
          && (
            existingData().senderId == request.auth.uid
            || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
          );

        allow delete: if isAuthenticated()
          && existingData().senderId == request.auth.uid;
      }
    }

    // ─── Notifications ─────────────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read: if isAuthenticated()
        && existingData().userId == request.auth.uid;

      allow create: if isAuthenticated()
        && isValidString(incomingData().userId)
        && isValidString(incomingData().title)
        && isValidString(incomingData().type)
        && incomingData().title.size() <= 200
        && incomingData().get('body', '').size() <= 500
        && (
          (incomingData().userId != request.auth.uid
            && incomingData().get('data', {}).get('senderId', request.auth.uid) == request.auth.uid)
          || (incomingData().userId == request.auth.uid
            && incomingData().type in ['karma_reward', 'system'])
        );

      allow update: if isAuthenticated()
        && existingData().userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);

      allow delete: if isAuthenticated()
        && existingData().userId == request.auth.uid;
    }

    // ─── Communities ─────────────────────────────────────────────────────
    match /communities/{communityId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isEmailVerified();
      allow update: if isAuthenticated()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberCount', 'updatedAt']);
      allow delete: if isModerator();
    }

    // ─── Reports ─────────────────────────────────────────────────────────
    match /reports/{reportId} {
      allow create: if isAuthenticated()
        && isEmailVerified()
        && incomingData().reporterId == request.auth.uid
        && isValidString(incomingData().reason);
      allow read: if isAuthenticated() && (
        existingData().reporterId == request.auth.uid || isModerator()
      );
      allow update: if isModerator();
      allow delete: if isAuthenticated() && (
        existingData().reporterId == request.auth.uid || isAdmin()
      );
    }

    // ─── Services ────────────────────────────────────────────────────────
    match /services/{serviceId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated()
        && isEmailVerified()
        && incomingData().userId == request.auth.uid
        && incomingData().get('isPremium', false) == false
        && incomingData().get('isVerified', false) == false
        && incomingData().get('verificationStatus', 'none') == 'none'
        && incomingData().get('subscriptionPlan', 'free') == 'free';

      allow update: if isAuthenticated() && (
        (existingData().userId == request.auth.uid
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(businessPrivilegedFields()))
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(businessOwnerOnlyFields())
        || isModerator()
      );

      allow delete: if (isAuthenticated() && existingData().userId == request.auth.uid) || isModerator();
    }

    match /service_reviews/{reviewId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && isEmailVerified()
        && incomingData().userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && existingData().userId == request.auth.uid;
    }

    // ─── Businesses ──────────────────────────────────────────────────────
    match /businesses/{businessId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated()
        && isEmailVerified()
        && incomingData().userId == request.auth.uid
        && incomingData().get('isPremium', false) == false
        && incomingData().get('isVerified', false) == false
        && incomingData().get('verificationStatus', 'none') == 'none'
        && incomingData().get('subscriptionPlan', 'free') == 'free';

      allow update: if isAuthenticated() && (
        (existingData().userId == request.auth.uid
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(businessPrivilegedFields()))
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(businessOwnerOnlyFields())
        || isModerator()
      );

      allow delete: if (isAuthenticated() && existingData().userId == request.auth.uid) || isModerator();
    }

    match /business_reviews/{reviewId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && isEmailVerified()
        && incomingData().userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && existingData().userId == request.auth.uid;
    }

    // ─── SOS Alerts ──────────────────────────────────────────────────────
    match /sos_alerts/{alertId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && isEmailVerified()
        && incomingData().creatorId == request.auth.uid;
      allow update: if isAuthenticated() && (
        existingData().creatorId == request.auth.uid
        || request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['responders', 'responderIds', 'status', 'respondersCount'])
      );
      allow delete: if isAuthenticated() && existingData().creatorId == request.auth.uid;
    }

    // ─── Subscription requests (premium) ─────────────────────────────────
    match /subscription_requests/{requestId} {
      allow read: if isAuthenticated() && (
        existingData().userId == request.auth.uid || isModerator()
      );
      allow create: if isAuthenticated()
        && isEmailVerified()
        && incomingData().userId == request.auth.uid
        && incomingData().status == 'pending';
      allow update, delete: if isModerator();
    }

    // ─── Security events (write via Cloud Functions only) ────────────────
    match /security_events/{eventId} {
      allow read: if isModerator();
      allow write: if false;
    }

    // ─── Rate limits (managed by Cloud Functions) ────────────────────────
    match /rate_limits/{limitId} {
      allow read, write: if false;
    }

    // ─── Deny everything else ────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
